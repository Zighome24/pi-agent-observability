# ─────────────────────────────────────────────────────────────────────────────
# pi-agent-observability — environment defaults
#
# Copy to .env (`cp .env.sample .env`) and edit only what you need. Every value
# below is OPTIONAL: the stack runs with these defaults out of the box. `just`
# auto-loads .env (set dotenv-load := true), so anything set here flows into
# `just all`, `just obs`, `just agent`, and the Steelman backend.
# ─────────────────────────────────────────────────────────────────────────────

# ── Observability server + extension ────────────────────────────────────────
# Shared bearer token across the obs server, the pi extension, and Steelman.
# Fine as "devtoken" on 127.0.0.1; set a real token anywhere else and don't
# share screenshots that include ?token=…
OBS_AUTH_TOKEN=devtoken
# Port + host the obs server listens on.
OBS_PORT=43190
OBS_HOST=127.0.0.1
# URL the extension + Steelman backend POST events to (keep in sync with OBS_PORT).
OBS_SERVER_URL=http://127.0.0.1:43190
# SQLite file path (parent dir is auto-created on boot).
# OBS_DB_PATH=db/obs.db
# Identity applied to `just agent` runs.
# OBS_POOL=manual-agent
# OBS_TAG=just-agent
# OBS_NAME=just-agent
# Set to "true" to disable the observability extension entirely.
# OBS_DISABLE=false

# ── Steelman product demo ────────────────────────────────────────────────────
# Backend API port + the Vite dev-server port.
STEELMAN_PORT=45210
STEELMAN_WEB_PORT=51730
# STEELMAN_HOST=127.0.0.1
# Vite /api proxy target (defaults to http://127.0.0.1:$STEELMAN_PORT).
# STEELMAN_API_TARGET=http://127.0.0.1:45210
# Model + provider the product agent runs on (forwarded to `pi --model` / `--provider`).
# Default = Google's Gemini 3.5 Flash → set GEMINI_API_KEY below (or `pi /login`).
STEELMAN_AGENT_MODEL=gemini-3.5-flash
STEELMAN_AGENT_MODEL_PROVIDER=google
# Path to the pi binary the backend spawns.
# STEELMAN_PI_BIN=pi
# Max real-agent run time (ms) before the backend marks the run errored.
# STEELMAN_AGENT_TIMEOUT_MS=180000
# Observability deep-link view from the product UI: "single" or "swimlane".
# STEELMAN_OBS_VIEW=single

# ── Research tool (steelman_research) ────────────────────────────────────────
# Firecrawl CLI; falls back to a dependency-light DuckDuckGo search if missing.
# FIRECRAWL_BIN=firecrawl
# FIRECRAWL_TIMEOUT_MS=20000
# FIRECRAWL_API_KEY=

# ── Provider API keys ────────────────────────────────────────────────────────
# Pi normally authenticates via `pi /login` (~/.pi/agent/auth.json). Set a key
# here only if you prefer env-based auth. The default agent runs on Google
# Gemini 3.5 Flash, so GEMINI_API_KEY (or GOOGLE_API_KEY) is the one that matters
# out of the box; the others are only for non-default models.
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
